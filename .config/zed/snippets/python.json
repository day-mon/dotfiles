{
  "uv script": {
    "prefix": "uvscript",
    "body": [
      "# /// script",
      "# requires-python = \"${1:>=3.12}\"",
      "# dependencies = [",
      "#   $2",
      "# ]",
      "# ///",
      "",
      "$0"
    ],
    "description": "uv inline script metadata block (PEP 723)"
  },
  "uv script with shebang": {
    "prefix": "uvshebang",
    "body": [
      "#!/usr/bin/env -S uv run --script",
      "# /// script",
      "# requires-python = \"${1:>=3.12}\"",
      "# dependencies = [",
      "#   $2",
      "# ]",
      "# ///",
      "",
      "$0"
    ],
    "description": "uv inline script with shebang for executable scripts"
  },
  "uv dep": {
    "prefix": "uvdep",
    "body": [
      "# /// script",
      "# dependencies = [",
      "#   \"$1\"",
      "# ]",
      "# ///",
      "",
      "$0"
    ],
    "description": "uv inline dependency block (minimal)"
  }
}
