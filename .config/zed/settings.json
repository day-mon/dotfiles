{
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "biome": {
      "settings": {
        "inline_config": {
          "linter": {
            "rules": {
              "performance": "all",
              "correctness": "all",
              "suspicious": "all",
              "complexity": "all"
            },
            "domains": {
              "playwright": "all",
              "test": "all",
              "types": "all",
              "react": "all"
            }
          }
        }
      }
    },
    "ruff": {
      "initialization_options": {
        "lint": {
          "extendSelect": [
            "PTH",
            "ARG",
            "RET",
            "RSE",
            "PYI",
            "EM",
            "DTZ",
            "ASYNC",
            "ANN",
            "TC",
            "I",
            "B",
            "FAST",
            "RUF",
            "TRY",
            "FURB",
            "PERF"
          ]
        }
      }
    }
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "single_file_review": true,
    "model_parameters": [
      {
        "temperature": 0
      }
    ]
  },
  "project_panel": {
    "dock": "right",
    "bold_folder_labels": true,
    "hide_gitignore": true
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "relative_line_numbers": "enabled",
  "icon_theme": {
    "mode": "dark",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark"
  },
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "JetBrains Dark"
  },
  "ui_font_family": "GeistMono Nerd Font Mono",
  "terminal": {
    "font_family": "GeistMono Nerd Font Mono",
    "shell": "system"
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "errors"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ],
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["tsgo", "biome", "!vtsls"],
      "inlay_hints": {
        "enabled": true
      }
    },
    "TSX": {
      "language_servers": ["tsgo", "biome", "!vtsls"]
    },
    "Python": {
      "colorize_brackets": true,
      "language_servers": ["ty", "pyrefly", "ruff", "!pyright", "!basedpyright"]
    }
  },
  "diff_view_style": "split",
  "toolbar": {
    "quick_actions": false
  },
  "auto_install_extensions": {
    "git-firefly": true,
    "ruff": true,
    "toml": true,
    "pyrefly": true,
    "dockerfile": true,
    "bione": true,
    "tombi": true
  }
}
