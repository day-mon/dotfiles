{
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "right",
  },
  "code_lens": "on",
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "lsp": {
    "tsgo": {},
    "biome": {
      "settings": {
        "inline_config": {
          "linter": {
            "rules": {
              "performance": "all",
              "correctness": "all",
              "suspicious": "all",
              "complexity": "all",
            },
            "domains": {
              "playwright": "all",
              "test": "all",
              "types": "all",
              "react": "all",
            },
          },
        },
      },
    },
    "ruff": {
      "initialization_options": {
        "lint": {
          "extendSelect": [
            "PTH",
            "ARG",
            "RET",
            "RSE",
            "PYI",
            "EM",
            "DTZ",
            "ASYNC",
            "LOG",
            "ANN",
            "TC",
            "PL",
            "SIM",
            "I",
            "Q",
            "B",
            "RSE",
            "FAST",
            "SLOT",
            "RUF",
            "TRY",
            "FURB",
            "PERF",
          ],
        },
      },
    },
  },
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": ["Company/us.anthropic.claude-opus-4-6-v1", "Company/gpt-5.5"],
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "single_file_review": true,
    "model_parameters": [
      {
        "temperature": 0,
      },
    ],
  },
  "project_panel": {
    "dock": "right",
    "bold_folder_labels": true,
    "hide_gitignore": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "relative_line_numbers": "enabled",
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "base_keymap": "JetBrains",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "file_types": {
    "Dockerfile": ["Dockerfile*"],
  },
  "ui_font_family": "GeistMono Nerd Font Mono",
  "terminal": {
    "font_family": "GeistMono Nerd Font Mono",
    "shell": "system",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "errors",
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules",
  ],
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "languages": {
    "TypeScript": {
      "language_servers": [
        "tsgo",
        "biome",
        "!vtsls",
        "!typescript-language-server",
      ],
    },
    "TSX": {
      "language_servers": [
        "tsgo",
        "biome",
        "!vtsls",
        "!typescript-language-server",
      ],
    },
    "Python": {
      "colorize_brackets": true,
      "language_servers": [
        "ty",
        "pyrefly",
        "ruff",
        "!pyright",
        "!basedpyright",
      ],
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
        "source.fixAll.ruff": true,
      },
    },
  },
  "diff_view_style": "split",
  "toolbar": {
    "quick_actions": false,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "auto_install_extensions": {
    "git-firefly": true,
    "ruff": true,
    "toml": true,
    "pyrefly": true,
    "dockerfile": true,
    "bione": true,
    "tsgo": true,
    "tombi": true,
  },
}
